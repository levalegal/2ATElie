/* Light theme - Atelier style */
/* Accent: warm terracotta/burgundy */

QMainWindow {
    background-color: #f5f5f5;
}

QWidget {
    background-color: #f5f5f5;
    color: #2d2d30;
}

QPushButton {
    background-color: #8b3a3a;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #a04545;
}

QPushButton:pressed {
    background-color: #6b2d2d;
}

QPushButton:disabled {
    background-color: #d0d0d0;
    color: #888888;
}

QPushButton#secondary {
    background-color: #e8e8e8;
    color: #2d2d30;
}

QPushButton#secondary:hover {
    background-color: #d8d8d8;
}

QLineEdit, QTextEdit, QPlainTextEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    background-color: white;
    color: #2d2d30;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    padding: 8px 12px;
    selection-background-color: #8b3a3a;
    selection-color: white;
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border-color: #8b3a3a;
}

QComboBox::drop-down {
    border: none;
    background: transparent;
}

QComboBox QAbstractItemView {
    background-color: white;
    selection-background-color: #8b3a3a;
    selection-color: white;
}

QTableWidget, QTableView {
    background-color: white;
    alternate-background-color: #fafafa;
    gridline-color: #e0e0e0;
    border: 1px solid #d0d0d0;
    border-radius: 8px;
}

QTableWidget::item, QTableView::item {
    padding: 8px;
}

QTableWidget::item:selected, QTableView::item:selected {
    background-color: #8b3a3a;
    color: white;
}

QHeaderView::section {
    background-color: #e8e8e8;
    color: #2d2d30;
    padding: 10px;
    border: none;
    border-bottom: 2px solid #8b3a3a;
}

QTabWidget::pane {
    border: 1px solid #d0d0d0;
    border-radius: 8px;
    background-color: #f5f5f5;
    top: -1px;
}

QTabBar::tab {
    background-color: #e8e8e8;
    color: #2d2d30;
    padding: 12px 24px;
    margin-right: 2px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
}

QTabBar::tab:selected {
    background-color: #8b3a3a;
    color: white;
}

QTabBar::tab:hover:!selected {
    background-color: #d8d8d8;
}

QGroupBox {
    font-weight: bold;
    border: 1px solid #d0d0d0;
    border-radius: 8px;
    margin-top: 12px;
    padding-top: 12px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    padding: 0 8px;
    color: #8b3a3a;
}

QScrollBar:vertical {
    background: #e8e8e8;
    width: 12px;
    border-radius: 6px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: #c0c0c0;
    border-radius: 6px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: #8b3a3a;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QMenuBar {
    background-color: #f5f5f5;
    color: #2d2d30;
}

QMenuBar::item:selected {
    background-color: #8b3a3a;
    color: white;
}

QMenu {
    background-color: white;
}

QMenu::item:selected {
    background-color: #8b3a3a;
    color: white;
}

QLabel {
    color: #2d2d30;
}

QLabel#title {
    font-size: 24px;
    font-weight: bold;
    color: #2d2d30;
}

QLabel#subtitle {
    font-size: 14px;
    color: #6b6b6b;
}

QFrame#sidebar {
    background-color: #e0e0e0;
}

/* Card style */
QFrame#card {
    background-color: white;
    border-radius: 12px;
    border: 1px solid #e0e0e0;
    padding: 16px;
}
